# =============================================================================
# Subscription Planner · Environment Variables · v2.1
# =============================================================================
# Copy this file to `.env.local` (never commit .env.local to Git).
# Fill in the real values from each service's dashboard.
# On Vercel, set these same variables in Project Settings > Environment Variables.
# =============================================================================
# v2.1 changes vs v2.0:
#   + RESEND_API_KEY, EMAIL_FROM        (resolves BLOCKER 3 — email provider)
#   + GOOGLE_MAPS_API_KEY               (resolves BLOCKER 4 — geocoding provider)
#   + S3_AUDIT_ARCHIVE_BUCKET           (90-day webhook archive + 7-year audit)
#   - AXIOM_TOKEN                       (removed — Vercel logs + Sentry sufficient
#                                        for pilot; deferred to post-pilot)
#
# Post-v2.1 (resolutions doc + commit 4):
#   + QSTASH_TOKEN, QSTASH_URL,
#     QSTASH_CURRENT_SIGNING_KEY,
#     QSTASH_NEXT_SIGNING_KEY           (resolves R-5 — durable queue mechanism;
#                                        replaces the unspecified Redis queue)
#   + SUITEFLEET_SANDBOX_USERNAME,
#     SUITEFLEET_SANDBOX_PASSWORD       (replaces CLIENT_SECRET — see ADR-007:
#                                        SuiteFleet uses username/password JWT,
#                                        not OAuth2 client credentials)
#   - SUITEFLEET_SANDBOX_CLIENT_SECRET  (removed — not part of SuiteFleet's
#                                        actual auth model; see ADR-007)
# =============================================================================


# -----------------------------------------------------------------------------
# APP CONFIG
# -----------------------------------------------------------------------------
# The public URL of your deployment. In dev use http://localhost:3000.
# In production this is your Vercel URL, e.g. https://planner.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Node environment — set automatically by Vercel; you only set this locally.
NODE_ENV=development

# A random string used to sign internal tokens (rotate quarterly).
# Generate with: openssl rand -base64 32
APP_SECRET=replace-with-random-32-byte-base64-string


# -----------------------------------------------------------------------------
# SUPABASE (Postgres database + Auth)
# -----------------------------------------------------------------------------
# From: Supabase Dashboard > Project Settings > API
# The URL is your project's API endpoint.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# The anon (public) key. Safe to expose to browsers.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# The service role key. NEVER expose to browsers. Server-only.
# Used ONLY for: migrations, seeds, admin console, system-actor cron jobs.
# Per non-negotiable in section 11.3, business-logic modules NEVER use this
# key combined with manual tenant_id filtering — they go through Supabase
# Auth + RLS. The service role key bypasses RLS; misuse breaks tenant
# isolation.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# =============================================================================
# Two Postgres connection strings (R-0, Day 2) — superuser + app role
# =============================================================================
# After R-0 we run two pools (src/shared/db.ts):
#   • SUPABASE_DATABASE_URL      — connects as the `postgres` superuser
#                                  (BYPASSRLS). Used by `withServiceRole`,
#                                  migrations, seeds, sysadmin scripts.
#   • SUPABASE_APP_DATABASE_URL  — connects as `planner_app` (NOBYPASSRLS,
#                                  created in supabase/migrations/0003_app_role.sql).
#                                  Used by `withTenant` for every business
#                                  query; RLS is the security boundary.
#
# Both URLs MUST point at the Supabase pooler (host
# `aws-0-<region>.pooler.supabase.com`, port `6543`) — Supabase Nano is
# IPv6-only and the direct `db.<ref>.supabase.co:5432` host is not reachable
# from Vercel's IPv4-only build/runtime network.
#
# To set up SUPABASE_APP_DATABASE_URL after applying 0003_app_role.sql:
#   1. In Supabase SQL editor (as project owner):
#        ALTER ROLE planner_app WITH LOGIN PASSWORD '<openssl rand -base64 32>';
#   2. Build the URL:
#        postgres://planner_app:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   3. Paste into Vercel (Production + Preview + Development) — paste source
#      MUST be a plain text editor; Excel/Numbers mangle silently.
# -----------------------------------------------------------------------------
# Superuser pool (postgres role, BYPASSRLS).
# From: Supabase Dashboard > Project Settings > Database > Connection string
#       (use the "Transaction pooler" form, not "Direct connection")
SUPABASE_DATABASE_URL=postgres://postgres:[PASSWORD]@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres

# App pool (planner_app role, NOBYPASSRLS). Same host as above, different
# user + password. RLS is enforced on this connection.
SUPABASE_APP_DATABASE_URL=postgres://planner_app:[PASSWORD]@aws-0-YOUR-REGION.pooler.supabase.com:6543/postgres


# -----------------------------------------------------------------------------
# UPSTASH REDIS (cache, rate limiting, JWT revocation, SuiteFleet JWT cache)
# -----------------------------------------------------------------------------
# From: Upstash Console > Your Database > REST API
UPSTASH_REDIS_REST_URL=https://YOUR-DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXXXXX...


# -----------------------------------------------------------------------------
# UPSTASH QSTASH (durable queue — added in resolutions R-5)
# -----------------------------------------------------------------------------
# QStash is the durable HTTP-based queue used for:
#   • tasks-to-push: nightly batch → SuiteFleet push consumer (plan §4.6.2)
#   • webhook Stage-2: inbound SuiteFleet webhook processing (R-6)
# It replaces the unspecified Redis queue from the original v2.1 plan.
# From: Upstash Console > QStash
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=eyJ...
QSTASH_CURRENT_SIGNING_KEY=sig_...
QSTASH_NEXT_SIGNING_KEY=sig_...


# -----------------------------------------------------------------------------
# AWS SECRETS MANAGER (per-tenant SuiteFleet credentials)
# -----------------------------------------------------------------------------
# AWS region — use me-south-1 (Bahrain) for lowest latency from UAE.
AWS_REGION=me-south-1

# IAM user credentials with scoped access to:
#   transcorp/planner/tenants/*
# Create this IAM user in AWS Console with a custom policy
# (template in docs/aws-iam-policy.json — Claude Code generates this on Day 3).
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...

# The path prefix under which all tenant secrets live.
# Do not change this without also changing the IAM policy.
SECRETS_MANAGER_PATH_PREFIX=transcorp/planner/tenants


# -----------------------------------------------------------------------------
# RESEND (transactional email — added in v2.1, BLOCKER 3 resolution)
# -----------------------------------------------------------------------------
# Used for: merchant invitations, batch summary emails, dead-letter alerts,
# credential-invalid alerts, MP-06 auto-pause notifications.
# From: Resend Dashboard > API Keys
RESEND_API_KEY=re_...

# The verified sender address. Must be on a domain you have set up SPF + DKIM
# for in Resend. For pilot, use a Transcorp-owned domain (e.g.
# planner@notifications.transcorp.ae). For initial development, the Resend
# sandbox domain (onboarding@resend.dev) is acceptable.
EMAIL_FROM=planner@notifications.transcorp.ae

# Internal distribution list that receives nightly batch summary emails
# (per section 4.6.4). Comma-separated.
EMAIL_INTERNAL_OPS_LIST=ops@transcorp.ae,engineering@transcorp.ae


# -----------------------------------------------------------------------------
# GOOGLE MAPS GEOCODING (added in v2.1, BLOCKER 4 resolution)
# -----------------------------------------------------------------------------
# Required by MP-06 (consignee validation must include geocoded coordinates
# before tasks can be generated). Wrapped behind src/shared/geocoder.ts so
# it is swappable.
# From: Google Cloud Console > APIs and Services > Credentials
# Restrict the key to: Geocoding API only, server-side only (no HTTP referrer).
GOOGLE_MAPS_API_KEY=AIza...


# -----------------------------------------------------------------------------
# SENTRY (error tracking)
# -----------------------------------------------------------------------------
# From: Sentry > Settings > Projects > planner > Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://XXXX@XXXX.ingest.sentry.io/XXXX

# Auth token for uploading source maps during build.
# From: Sentry > Settings > Account > Auth Tokens
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=planner

# Sentry SDK init must scrub PII from URL paths and breadcrumbs (per
# Concern 14 in the v2.0 review). Configure beforeSend to redact phone
# numbers and consignee names from request URLs and breadcrumbs.


# -----------------------------------------------------------------------------
# VERCEL CRON (for the nightly task generation batch + reconciliation)
# -----------------------------------------------------------------------------
# A random secret to protect /api/internal/cron/* endpoints.
# Vercel Cron sends this as: Authorization: Bearer ${CRON_SECRET}
# The system-actor middleware validates this header and constructs a
# SystemContext with the appropriate cron permission set (sections 7.4.1
# and 7.4.2).
# Generate with: openssl rand -base64 32
CRON_SECRET=replace-with-random-32-byte-base64-string


# -----------------------------------------------------------------------------
# S3 ARCHIVE (added in v2.1)
# -----------------------------------------------------------------------------
# Webhook events archived after 90 days; audit log archived after 12 months.
# Bucket should be in the same AWS region with lifecycle rules configured for
# Glacier transition.
S3_AUDIT_ARCHIVE_BUCKET=transcorp-planner-archive
S3_AUDIT_ARCHIVE_PREFIX=audit/
S3_WEBHOOK_ARCHIVE_PREFIX=webhooks/


# -----------------------------------------------------------------------------
# SUITEFLEET SANDBOX (for testing before pilot)
# -----------------------------------------------------------------------------
# These are NOT used by the production app — production uses per-tenant
# credentials from AWS Secrets Manager. These are for development testing only.
# Load them into Secrets Manager under:
#   transcorp/planner/tenants/SANDBOX/suitefleet/sandbox
#
# IMPORTANT (per ADR-007 — supersedes plan §5.6.1): SuiteFleet v2 uses
# username/password authentication, not OAuth2 client credentials. The
# username + password are POSTed to a login endpoint (exact path verified
# on Day 4 against the SuiteFleet sandbox docs before adapter code is
# written) and a 24-hour JWT is returned. Subsequent API calls send TWO
# headers, not one:
#   Authorization: Bearer <jwt>
#   Clientid: <client_id>
# CLIENT_ID is a tenant-routing identifier on every request, not an
# OAuth2 credential. The JWT is cached in Upstash Redis under
# `sf:jwt:${tenantId}:${environment}` with TTL = (expiry − 60s).
SUITEFLEET_SANDBOX_API_BASE_URL=https://api.suitefleet.com/api
SUITEFLEET_SANDBOX_CLIENT_ID=...
SUITEFLEET_SANDBOX_USERNAME=...
SUITEFLEET_SANDBOX_PASSWORD=...
SUITEFLEET_SANDBOX_ACCOUNT_ID=...


# -----------------------------------------------------------------------------
# FEATURE FLAGS (for the pilot)
# -----------------------------------------------------------------------------
# Enable Arabic locale in the UI. Set to 'false' for English-only pilot launch.
NEXT_PUBLIC_ENABLE_ARABIC=false

# Show the reconciliation job in the admin UI. Default off during pilot.
ENABLE_RECONCILIATION_ADMIN=false


# -----------------------------------------------------------------------------
# OBSERVABILITY — Axiom REMOVED in v2.1
# -----------------------------------------------------------------------------
# Vercel logs (24h retention on Pro) + Sentry are sufficient for pilot.
# Dedicated log aggregation (Axiom, Better Stack, Datadog) is deferred to
# post-pilot. See section 13.5 of the plan.
